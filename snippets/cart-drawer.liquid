{% doc %}
  Slide-out cart drawer: AJAX updates via assets/cart-drawer.js
{% enddoc %}
{% assign free_shipping_threshold_cents = settings.free_shipping_threshold | default: 50 | times: 100 %}
{% assign threshold_display = free_shipping_threshold_cents | money %}
{% assign free_shipping_amount_placeholder = '{' | append: 'amount' | append: '}' %}
<div
  class="cart-drawer"
  id="cart-drawer"
  aria-hidden="true"
  data-free-shipping-threshold-cents="{{ free_shipping_threshold_cents }}"
  data-money-format="{{ shop.money_format | escape }}"
  data-text-empty="{{ 'cart.empty' | t | escape }}"
  data-text-shipping-threshold="{{ 'cart.drawer_free_shipping_over' | t | escape }}"
  data-text-unlocked="{{ 'cart.drawer_free_shipping_unlocked' | t | escape }}"
  data-text-away="{{ 'cart.drawer_free_shipping_away' | t | escape }}"
>
  <div class="cart-drawer__overlay" data-cart-drawer-close tabindex="-1" aria-hidden="true"></div>
  <aside class="cart-drawer__panel" role="dialog" aria-modal="true" aria-labelledby="cart-drawer-title">
    <header class="cart-drawer__header">
      <div class="cart-drawer__header-main">
        <h2 id="cart-drawer-title" class="cart-drawer__title">{{ 'cart.drawer_title' | t }}</h2>
        <span id="cart-drawer-count" class="cart-drawer__badge" hidden aria-live="polite">0</span>
      </div>
      <button type="button" class="cart-drawer__close" data-cart-drawer-close aria-label="{{ 'cart.close_drawer' | t }}">
        <span aria-hidden="true">&times;</span>
        <span class="visually-hidden">{{ 'cart.close_drawer' | t }}</span>
      </button>
    </header>

    <div class="cart-drawer__body" id="cart-drawer-items">
      <p class="cart-drawer__empty">{{ 'cart.empty' | t }}</p>
    </div>

    <footer class="cart-drawer__footer">
      <div class="cart-drawer__free-shipping">
        <p class="cart-drawer__free-shipping-text" id="cart-drawer-free-shipping-text">
          {{ 'cart.drawer_free_shipping_over' | t | replace: free_shipping_amount_placeholder, threshold_display }}
        </p>
        <div class="cart-drawer__free-shipping-track" aria-hidden="true">
          <div class="cart-drawer__free-shipping-fill" id="cart-drawer-free-shipping-fill" style="width: 0%"></div>
        </div>
      </div>

      <div class="cart-drawer__summary">
        <span>{{ 'cart.subtotal' | t }}</span>
        <span id="cart-drawer-subtotal">{{ cart.total_price | money }}</span>
      </div>
      <a
        class="cart-drawer__checkout"
        href="{{ cart.checkout_url | default: routes.checkout_url }}"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M7 11V7a5 5 0 0110 0v4M6 11h12v10a1 1 0 01-1 1H7a1 1 0 01-1-1V11z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {{ 'cart.secure_checkout' | t }}
      </a>
    </footer>
  </aside>
</div>

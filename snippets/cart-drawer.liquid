{% assign free_shipping_threshold_cents = settings.free_shipping_threshold | default: 50 | times: 100 %}
<div class="cart-drawer" id="cart-drawer" aria-hidden="true" data-free-shipping-threshold-cents="{{ free_shipping_threshold_cents }}">
  <div class="cart-drawer__overlay" data-cart-drawer-close></div>
  <aside class="cart-drawer__panel" role="dialog" aria-modal="true" aria-labelledby="cart-drawer-title">
    <header class="cart-drawer__header">
      <h2 id="cart-drawer-title" class="cart-drawer__title">{{ 'cart.title' | t }}</h2>
      <button type="button" class="cart-drawer__close" data-cart-drawer-close>&times;</button>
    </header>

    <div class="cart-drawer__body" id="cart-drawer-items">
      <p class="cart-drawer__empty">{{ 'cart.empty' | t }}</p>
    </div>

    <footer class="cart-drawer__footer">
      <div class="cart-drawer__free-shipping">
        <p class="cart-drawer__free-shipping-text" id="cart-drawer-free-shipping-text">
          Free shipping on orders over {{ settings.free_shipping_threshold | default: 50 | money }}
        </p>
        <div class="cart-drawer__free-shipping-track" aria-hidden="true">
          <div class="cart-drawer__free-shipping-fill" id="cart-drawer-free-shipping-fill" style="width: 0%"></div>
        </div>
      </div>

      <div class="cart-drawer__summary">
        <span>{{ 'cart.subtotal' | t }}</span>
        <span id="cart-drawer-subtotal">{{ cart.total_price | money }}</span>
      </div>
      <a class="cart-drawer__checkout" href="{{ routes.checkout_url }}">
        {{ 'cart.checkout' | t }}
      </a>
    </footer>
  </aside>
</div>

{% stylesheet %}
  .cart-drawer {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    pointer-events: none;
  }

  .cart-drawer.is-open {
    display: block;
    pointer-events: auto;
  }

  .cart-drawer__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.01);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .cart-drawer.is-open .cart-drawer__overlay {
    background: rgba(0, 0, 0, 0.35);
    opacity: 1;
  }

  .cart-drawer__panel {
    position: absolute;
    top: 0;
    right: 0;
    width: min(420px, 100%);
    height: 100%;
    background: var(--color-background);
    display: flex;
    flex-direction: column;
    box-shadow: -8px 0 24px rgba(0, 0, 0, 0.15);
    transform: translateX(110%);
    opacity: 0;
    transition:
      transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1),
      opacity 0.25s ease;
  }

  .cart-drawer.is-open .cart-drawer__panel {
    transform: translateX(0);
    opacity: 1;
  }

  .cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid var(--color-border);
  }

  .cart-drawer__title {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
  }

  .cart-drawer__close {
    background: none;
    border: none;
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
  }

  .cart-drawer__body {
    flex: 1;
    overflow-y: auto;
    padding: 16px 20px;
  }

  .cart-drawer__item {
    display: grid;
    grid-template-columns: 64px 1fr auto;
    gap: 12px;
    align-items: center;
    margin-bottom: 16px;
  }

  .cart-drawer__item img {
    width: 64px;
    height: 64px;
    object-fit: cover;
    border-radius: 8px;
  }

  .cart-drawer__item-title {
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 4px;
  }

  .cart-drawer__item-meta {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .cart-drawer__item-qty {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
  }

  .cart-drawer__qty-btn {
    width: 22px;
    height: 22px;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    cursor: pointer;
  }

  .cart-drawer__item-price {
    font-size: 0.9rem;
    font-weight: 600;
  }

  .cart-drawer__footer {
    padding: 16px 20px 20px;
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .cart-drawer__free-shipping {
    display: grid;
    gap: 8px;
  }

  .cart-drawer__free-shipping-text {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-foreground);
    font-weight: 500;
  }

  .cart-drawer__free-shipping-track {
    height: 4px;
    background: rgba(0, 0, 0, 0.12);
    border-radius: 999px;
    overflow: hidden;
  }

  .cart-drawer__free-shipping-fill {
    height: 100%;
    width: 0%;
    background: var(--color-accent);
    border-radius: 999px;
    transition: width 0.35s ease;
  }

  .cart-drawer__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.95rem;
    font-weight: 500;
  }

  .cart-drawer__checkout {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 12px 16px;
    border: none;
    border-radius: 999px;
    background: var(--color-accent);
    color: #fff;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
  }
{% endstylesheet %}


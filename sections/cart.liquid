{% comment %}
  Cart page — clean, intuitive layout.
  https://shopify.dev/docs/storefronts/themes/architecture/templates/cart
{% endcomment %}

<div class="cart-page">
  <h1 class="cart-page__heading">{{ 'cart.title' | t }}</h1>

  {% if cart.item_count == 0 %}
    <div class="cart-page__empty">
      <p class="cart-page__empty-text">{{ 'cart.empty' | t }}</p>
      <a href="{{ routes.all_products_collection_url }}" class="cart-page__continue-btn">
        {{ 'cart.continue_shopping' | t }}
      </a>
    </div>
  {% else %}
    <div class="cart-page__layout">

      <div class="cart-page__items">
        <form action="{{ routes.cart_url }}" method="post" id="cart-form">
          {% for item in cart.items %}
            <div class="cart-item">
              <a href="{{ item.url }}" class="cart-item__image">
                {% if item.image %}
                  <img
                    src="{{ item.image | image_url: width: 200 }}"
                    alt="{{ item.image.alt | default: item.product.title | escape }}"
                    width="200"
                    height="200"
                    loading="lazy"
                  >
                {% endif %}
              </a>

              <div class="cart-item__details">
                <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>

                {% unless item.product.has_only_default_variant %}
                  <p class="cart-item__variant">{{ item.variant.title }}</p>
                {% endunless %}

                <p class="cart-item__price">{{ item.original_line_price | money }}</p>

                <div class="cart-item__actions">
                  <div class="cart-item__quantity">
                    <label class="visually-hidden" for="quantity-{{ item.index }}">{{ 'cart.quantity' | t }}</label>
                    <button type="button" class="cart-item__qty-btn" data-action="decrease" data-index="{{ item.index }}">−</button>
                    <input
                      class="cart-item__qty-input"
                      type="number"
                      name="updates[]"
                      id="quantity-{{ item.index }}"
                      value="{{ item.quantity }}"
                      min="0"
                      aria-label="{{ 'cart.quantity' | t }}"
                    >
                    <button type="button" class="cart-item__qty-btn" data-action="increase" data-index="{{ item.index }}">+</button>
                  </div>
                  <a href="{{ item.url_to_remove }}" class="cart-item__remove">{{ 'cart.remove' | t }}</a>
                </div>
              </div>
            </div>
          {% endfor %}
        </form>
      </div>

      <div class="cart-page__summary">
        <div class="cart-summary">
          <h2 class="cart-summary__heading">{{ 'cart.summary' | t }}</h2>

          <div class="cart-summary__row">
            <span>{{ 'cart.subtotal' | t }}</span>
            <span>{{ cart.total_price | money }}</span>
          </div>

          <div class="cart-summary__row cart-summary__row--light">
            <span>{{ 'cart.shipping' | t }}</span>
            <span>{{ 'cart.calculated_at_checkout' | t }}</span>
          </div>

          <div class="cart-summary__divider"></div>

          <div class="cart-summary__row cart-summary__row--total">
            <span>{{ 'cart.total' | t }}</span>
            <span>{{ cart.total_price | money }}</span>
          </div>

          <button type="submit" name="checkout" form="cart-form" class="cart-summary__checkout-btn">
            {{ 'cart.checkout' | t }}
          </button>

          <a href="{{ routes.all_products_collection_url }}" class="cart-summary__continue">
            {{ 'cart.continue_shopping' | t }}
          </a>
        </div>
      </div>

    </div>
  {% endif %}
</div>

{% stylesheet %}
  .cart-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .cart-page__heading {
    font-size: 2rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 40px;
  }

  /* Empty state */
  .cart-page__empty {
    text-align: center;
    padding: 60px 0;
  }

  .cart-page__empty-text {
    font-size: 1.1rem;
    color: #666;
    margin-bottom: 24px;
  }

  .cart-page__continue-btn {
    display: inline-block;
    background: #1a1a1a;
    color: #fff;
    text-decoration: none;
    padding: 14px 32px;
    border-radius: 50px;
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: background 0.2s;
  }

  .cart-page__continue-btn:hover {
    background: #333;
  }

  /* Layout */
  .cart-page__layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 48px;
    align-items: start;
  }

  @media (max-width: 800px) {
    .cart-page__layout {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  /* Cart items */
  .cart-item {
    display: flex;
    gap: 20px;
    padding: 24px 0;
    border-bottom: 1px solid #f0f0f0;
  }

  .cart-item:first-child {
    padding-top: 0;
  }

  .cart-item__image {
    width: 100px;
    height: 100px;
    border-radius: 12px;
    overflow: hidden;
    background: #f5f5f5;
    flex-shrink: 0;
  }

  .cart-item__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-item__details {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .cart-item__title {
    font-size: 0.95rem;
    font-weight: 600;
    color: #1a1a1a;
    text-decoration: none;
  }

  .cart-item__title:hover {
    opacity: 0.7;
  }

  .cart-item__variant {
    font-size: 0.8rem;
    color: #888;
    margin: 0;
  }

  .cart-item__price {
    font-size: 0.95rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 4px 0 0;
  }

  .cart-item__actions {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 8px;
  }

  .cart-item__quantity {
    display: flex;
    align-items: center;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    overflow: hidden;
  }

  .cart-item__qty-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fafafa;
    border: none;
    font-size: 16px;
    color: #333;
    cursor: pointer;
    transition: background 0.15s;
    font-family: inherit;
  }

  .cart-item__qty-btn:hover {
    background: #f0f0f0;
  }

  .cart-item__qty-input {
    width: 40px;
    height: 36px;
    text-align: center;
    border: none;
    border-left: 1px solid #e0e0e0;
    border-right: 1px solid #e0e0e0;
    font-size: 14px;
    font-weight: 600;
    color: #1a1a1a;
    -moz-appearance: textfield;
    background: #fff;
  }

  .cart-item__qty-input::-webkit-outer-spin-button,
  .cart-item__qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .cart-item__remove {
    font-size: 0.8rem;
    color: #999;
    text-decoration: none;
    transition: color 0.15s;
  }

  .cart-item__remove:hover {
    color: #c00;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  /* Summary */
  .cart-summary {
    background: #fafafa;
    border-radius: 16px;
    padding: 32px;
    position: sticky;
    top: 24px;
  }

  .cart-summary__heading {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 24px;
  }

  .cart-summary__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.95rem;
    color: #1a1a1a;
    padding: 8px 0;
  }

  .cart-summary__row--light {
    color: #888;
    font-size: 0.85rem;
  }

  .cart-summary__row--total {
    font-size: 1.1rem;
    font-weight: 700;
  }

  .cart-summary__divider {
    height: 1px;
    background: #e5e5e5;
    margin: 12px 0;
  }

  .cart-summary__checkout-btn {
    display: block;
    width: 100%;
    background: #1a1a1a;
    color: #fff;
    border: none;
    padding: 16px;
    border-radius: 50px;
    font-size: 15px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background 0.2s;
    margin-top: 24px;
    font-family: inherit;
  }

  .cart-summary__checkout-btn:hover {
    background: #333;
  }

  .cart-summary__continue {
    display: block;
    text-align: center;
    margin-top: 16px;
    font-size: 0.85rem;
    color: #888;
    text-decoration: none;
    transition: color 0.15s;
  }

  .cart-summary__continue:hover {
    color: #1a1a1a;
  }
{% endstylesheet %}

{% javascript %}
  document.querySelectorAll('.cart-item__qty-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var input = this.parentElement.querySelector('.cart-item__qty-input');
      var val = parseInt(input.value, 10) || 0;
      if (this.dataset.action === 'increase') {
        input.value = val + 1;
      } else if (this.dataset.action === 'decrease' && val > 0) {
        input.value = val - 1;
      }
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}

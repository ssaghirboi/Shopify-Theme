<header class="full-width">
  <div class="header__left">
    <div class="header__menu">
      {% for link in section.settings.menu.links %}
        {{ link.title | link_to: link.url }}
      {% endfor %}
    </div>
  </div>

  <div class="header__center">
    <a href="{{ routes.root_url }}" class="header__logo">{{ shop.name }}</a>
  </div>

  <div class="header__right">
    {% if shop.customer_accounts_enabled %}
      <shopify-account menu="{{ section.settings.customer_account_menu }}">
        {{ 'icon-account.svg' | inline_asset_content }}
      </shopify-account>
    {% endif %}

    <a
      href="#"
      class="header__cart"
      data-open-cart-drawer
      aria-label="{{ 'cart.open_cart' | t }}"
    >
      {% if cart.item_count > 0 %}
        <span class="header__cart-count">{{ cart.item_count }}</span>
      {% endif %}
      {{ 'icon-cart.svg' | inline_asset_content }}
    </a>
  </div>
</header>

{% stylesheet %}
  header {
    position: relative;
    height: 5rem;
    display: flex;
    align-items: stretch;
    padding: 0 32px;
    background: var(--color-background);
    border-bottom: 1px solid var(--color-border);
    z-index: 30;
  }

  @media (max-width: 749px) {
    header {
      padding: 0 16px;
      height: 4.5rem;
    }

    .header__logo {
      font-size: clamp(0.85rem, 3.2vw, 1.15rem);
      letter-spacing: 0.18em;
      max-width: min(11rem, 46vw);
    }
  }


  .header__left,
  .header__right {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .header__right {
    justify-content: flex-end;
  }

  .header__center {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .header__logo {
    pointer-events: auto;
    text-decoration: none;
    color: var(--color-foreground);
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    white-space: nowrap;
    line-height: 1;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .header__logo:hover {
    color: var(--color-foreground);
    opacity: 0.75;
  }

  .header__menu {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .header__menu a {
    text-decoration: none;
    color: var(--color-foreground);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.75;
    transition: opacity 0.2s;
  }

  .header__menu a:hover {
    opacity: 1;
  }

  .header__right a,
  .header__right shopify-account {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-foreground);
    text-decoration: none;
  }

  .header__right svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .header__cart {
    position: relative;
  }

  .header__cart-count {
    position: absolute;
    top: -6px;
    right: -8px;
    background: var(--color-foreground);
    color: var(--color-background);
    font-size: 0.6rem;
    font-weight: 700;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}

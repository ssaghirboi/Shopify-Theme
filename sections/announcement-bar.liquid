<div class="announcement-bar" style="--bg: {{ section.settings.background_color }}; --color: {{ section.settings.text_color }};">
  <p class="announcement-bar__text">{{ section.settings.text }}</p>
</div>

{% stylesheet %}
  .announcement-bar {
    background-color: var(--bg);
    color: var(--color);
    text-align: center;
    padding: 10px 16px;
    width: 100%;
  }

  .announcement-bar__text {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.05em;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.announcement_bar.name",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "t:labels.text",
      "default": "HELLO"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background_color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:labels.text_color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "t:sections.announcement_bar.name"
    }
  ]
}
{% endschema %}

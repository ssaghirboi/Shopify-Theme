<section class="hero full-width">
  {% if section.settings.video_url != blank %}
    <video
      class="hero__video"
      autoplay
      muted
      loop
      playsinline
      poster="{% if section.settings.image %}{{ section.settings.image | image_url: width: 1920 }}{% endif %}"
    >
      <source src="{{ section.settings.video_url }}" type="video/mp4">
    </video>
  {% elsif section.settings.shopify_video %}
    {{ section.settings.shopify_video | video_tag:
      autoplay: true,
      muted: true,
      loop: true,
      playsinline: true,
      class: 'hero__video'
    }}
  {% elsif section.settings.image %}
    <img
      class="hero__image"
      src="{{ section.settings.image | image_url: width: 1920 }}"
      alt="{{ section.settings.image.alt | escape }}"
      loading="eager"
      width="1920"
      height="900"
    >
  {% endif %}

  <div class="hero__overlay"></div>

  <div class="hero__content">
    {% if section.settings.subtitle != blank %}
      <p class="hero__subtitle">{{ section.settings.subtitle }}</p>
    {% endif %}

    <h1 class="hero__title">{{ section.settings.title }}</h1>

    {% if section.settings.description != blank %}
      <p class="hero__description">{{ section.settings.description }}</p>
    {% endif %}

    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_url }}" class="hero__button">
        {{ section.settings.button_text }}
      </a>
    {% endif %}

    {% if section.settings.show_rating %}
      <div class="hero__rating">
        <span class="hero__stars">★★★★★</span>
        <span class="hero__rating-text">{{ section.settings.rating_text }}</span>
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: min(52vh, 620px);
    overflow: hidden;
    background-color: #141c2e;
  }

  .hero__video,
  .hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.6));
    z-index: 2;
  }

  .hero__content {
    position: relative;
    z-index: 3;
    text-align: center;
    color: #fff;
    max-width: min(640px, 100%);
    width: 100%;
    min-width: 0;
    padding: 28px 20px 32px;
    box-sizing: border-box;
  }

  .hero__subtitle {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 12px;
    opacity: 0.88;
    font-weight: 600;
  }

  .hero__title {
    font-size: clamp(1.85rem, 4.2vw, 3rem);
    font-weight: 700;
    line-height: 1.12;
    margin-bottom: 14px;
    letter-spacing: -0.02em;
  }

  .hero__description {
    font-size: 0.95rem;
    line-height: 1.55;
    opacity: 0.88;
    margin-bottom: 22px;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero__button {
    display: inline-block;
    width: auto;
    max-width: 100%;
    background-color: #2d4a7a;
    color: #fff;
    padding: 14px 28px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    text-decoration: none;
    border-radius: 14px;
    transition: background-color 0.25s ease, transform 0.2s ease;
  }

  .hero__button:hover {
    background-color: #243d66;
    transform: translateY(-1px);
  }

  .hero__rating {
    margin-top: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .hero__stars {
    color: rgba(255, 255, 255, 0.55);
    font-size: 15px;
    letter-spacing: 0.12em;
  }

  .hero__rating-text {
    font-size: 12px;
    opacity: 0.85;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  /* Mobile: tighter side margins, headline-forward layout (reference: compact DTC hero) */
  @media (max-width: 749px) {
    .hero {
      min-height: min(52vh, 500px);
      align-items: center;
    }

    .hero__overlay {
      background: linear-gradient(to bottom, rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0.62));
    }

    .hero__content {
      max-width: 100%;
      padding: 18px 16px 22px;
    }

    .hero__subtitle {
      font-size: 10px;
      letter-spacing: 0.16em;
      margin-bottom: 10px;
    }

    .hero__title {
      font-size: clamp(2rem, 8.75vw, 2.65rem);
      line-height: 1.05;
      margin-bottom: 12px;
      letter-spacing: -0.03em;
    }

    .hero__description {
      font-size: 0.875rem;
      line-height: 1.5;
      margin-bottom: 16px;
      max-width: 26rem;
      opacity: 0.9;
    }

    .hero__button {
      padding: 11px 20px;
      font-size: 10px;
      letter-spacing: 0.11em;
      border-radius: 12px;
    }

    .hero__rating {
      margin-top: 14px;
      gap: 6px;
    }

    .hero__stars {
      font-size: 13px;
    }

    .hero__rating-text {
      font-size: 11px;
      letter-spacing: 0.06em;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "header",
      "content": "Background Media"
    },
    {
      "type": "video",
      "id": "shopify_video",
      "label": "Video (upload)",
      "info": "Upload a video directly to Shopify. This takes priority over an external URL."
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (external)",
      "info": "Direct link to an .mp4 file. Used if no Shopify video is uploaded."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Fallback Image",
      "info": "Shown while video loads, or if no video is set."
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Trusted by 25,000+ Customers"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Radiant Skin Powered by Light"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Professional-grade LED mask for smoother, firmer, younger-looking skin."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "GET STARTED TODAY"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show Rating",
      "default": true
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating Text",
      "default": "4.9 Excellent"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}

<section class="product-features">
  <div class="product-features__inner">
    <div class="product-features__image">
      {% if section.settings.image %}
        <img
          src="{{ section.settings.image | image_url: width: 800 }}"
          alt="{{ section.settings.title | escape }}"
          loading="lazy"
          width="800"
          height="800"
        >
      {% else %}
        <div class="product-features__placeholder"></div>
      {% endif %}
    </div>

    <div class="product-features__content">
      {% if section.settings.title != blank %}
        <h2 class="product-features__title">{{ section.settings.title }}</h2>
      {% endif %}

      <ul class="product-features__list">
        {% for block in section.blocks %}
          <li class="product-features__item" {{ block.shopify_attributes }}>
            <div class="product-features__icon">&#10003;</div>
            <div class="product-features__text">
              <h3 class="product-features__heading">{{ block.settings.heading }}</h3>
              {% if block.settings.description != blank %}
                <p class="product-features__description">{{ block.settings.description }}</p>
              {% endif %}
            </div>
          </li>
        {% endfor %}
      </ul>
    </div>
  </div>
</section>

{% stylesheet %}
  .product-features {
    padding: 56px 24px;
  }

  .product-features__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
  }

  @media (max-width: 800px) {
    .product-features__inner {
      grid-template-columns: 1fr;
      gap: 40px;
      max-width: 550px;
    }
  }

  .product-features__image {
    border-radius: 20px;
    overflow: hidden;
    background: #f5f5f5;
    aspect-ratio: 1 / 1;
  }

  .product-features__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-features__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #e8e8e8 0%, #d0d0d0 100%);
  }

  .product-features__title {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 700;
    color: var(--color-foreground);
    margin-bottom: 32px;
    line-height: 1.2;
  }

  .product-features__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .product-features__item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .product-features__icon {
    width: 28px;
    height: 28px;
    min-width: 28px;
    border-radius: 50%;
    background: var(--color-accent-light);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
    margin-top: 2px;
  }

  .product-features__heading {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-foreground);
    margin-bottom: 4px;
    line-height: 1.3;
  }

  .product-features__description {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.product_features.name",
  "blocks": [
    {
      "type": "feature",
      "name": "t:sections.product_features.blocks.feature.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.product_features.blocks.feature.heading",
          "default": "Feature heading"
        },
        {
          "type": "text",
          "id": "description",
          "label": "t:sections.product_features.blocks.feature.description",
          "default": "Brief description of this feature."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:labels.title",
      "default": "How it works"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.product_features.image"
    }
  ],
  "presets": [
    {
      "name": "t:sections.product_features.name"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
